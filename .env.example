# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# TURSO_DB_URL: The HTTP URL of your Turso Edge Database (e.g. https://my-db.turso.io)
TURSO_DB_URL=https://your-turso-database-url.turso.io

# TURSO_AUTH_TOKEN: The bearer authentication token created via turso CLI
TURSO_AUTH_TOKEN=your_turso_token_here

# GOOGLE_DRIVE_FOLDER_ID: The unique folder ID in Google Drive to store journal images (optional)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

